rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isCoupleMemeber(coupleId) {
      return isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    // couples 컬렉션
    match /couples/{coupleId} {
      // 멤버만 읽기, 생성은 인증된 사용자 (새 커플 생성)
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isCoupleMemeber(coupleId);
      allow delete: if false;

      // items (일정/일기/사진 등) — 멤버만
      match /items/{itemId} {
        allow read: if isCoupleMemeber(coupleId);
        allow create: if isCoupleMemeber(coupleId);
        allow update: if isCoupleMemeber(coupleId);
        allow delete: if isCoupleMemeber(coupleId);
      }

      // messages (채팅) — 멤버만
      match /messages/{messageId} {
        allow read: if isCoupleMemeber(coupleId);
        allow create: if isCoupleMemeber(coupleId);
        allow update: if isCoupleMemeber(coupleId);
        allow delete: if isCoupleMemeber(coupleId);
      }
    }

    // pairing — 본인 이메일 문서만 생성/수정
    match /pairing/{email} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.token.email == email;
      allow update: if isAuth();
      allow delete: if isAuth() && request.auth.token.email == email;
    }
  }
}
