rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // ─── couples 컬렉션 ───
    match /couples/{coupleId} {
      allow read, write: if isAuth();

      // items (일정/일기/사진 등)
      match /items/{itemId} {
        allow read, write: if isAuth();
      }

      // messages (채팅)
      match /messages/{messageId} {
        allow read, write: if isAuth();
      }
    }

    // ─── pairing ───
    match /pairing/{email} {
      allow read, write: if isAuth();
    }
  }
}
