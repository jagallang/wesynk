rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── 헬퍼 함수 ───

    function isAuth() {
      return request.auth != null;
    }

    // 해당 커플의 멤버인지 확인 (members 배열에 이메일 포함)
    function isMember(coupleId) {
      return isAuth() &&
        request.auth.token.email in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    // ─── couples 컬렉션 ───
    match /couples/{coupleId} {
      // 읽기: 인증된 사용자 (문서 존재 확인, 페어링 초기화에 필요)
      allow read: if isAuth();
      // 생성: 인증 + 본인 이메일이 members에 포함
      allow create: if isAuth() &&
        request.resource.data.members is list &&
        request.auth.token.email in request.resource.data.members;
      // 수정: 인증된 사용자 (members 마이그레이션 허용)
      allow update: if isAuth();
      allow delete: if false;

      // items (일정/일기/사진 등) — 멤버만 접근
      match /items/{itemId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }

      // messages (채팅) — 멤버만 접근
      match /messages/{messageId} {
        allow read: if isMember(coupleId);
        allow create: if isMember(coupleId);
        allow update: if isMember(coupleId);
        allow delete: if isMember(coupleId);
      }
    }

    // ─── pairing — 본인 이메일 문서만 쓰기 ───
    match /pairing/{email} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() &&
        email == request.auth.token.email;
    }
  }
}
